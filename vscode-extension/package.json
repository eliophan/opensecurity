{
    "name": "opensecurity-vscode",
    "displayName": "OpenSecurity",
    "description": "Security scanner for VS Code — quick scan + inline highlights",
    "version": "0.1.0",
    "publisher": "opensecurity",
    "license": "MIT",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Linters",
        "Other"
    ],
    "activationEvents": [
        "onCommand:opensecurity.scan",
        "onCommand:opensecurity.clearDiagnostics"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "opensecurity.scan",
                "title": "OpenSecurity: Run Security Scan"
            },
            {
                "command": "opensecurity.clearDiagnostics",
                "title": "OpenSecurity: Clear Diagnostics"
            }
        ],
        "configuration": {
            "title": "OpenSecurity",
            "properties": {
                "opensecurity.noAi": {
                    "type": "boolean",
                    "default": false,
                    "description": "Skip AI model scanning (use only static analysis)"
                },
                "opensecurity.rulesPath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to custom OWASP rules JSON file"
                },
                "opensecurity.cveCachePath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to CVE cache JSON file"
                },
                "opensecurity.dataSensitivity": {
                    "type": "string",
                    "enum": [
                        "low",
                        "medium",
                        "high"
                    ],
                    "default": "medium",
                    "description": "Data sensitivity level for risk scoring"
                },
                "opensecurity.scanOnSave": {
                    "type": "boolean",
                    "default": false,
                    "description": "Automatically scan files on save"
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "lint": "eslint src",
        "package": "npx -y @vscode/vsce package --no-dependencies",
        "pretest": "npm run compile"
    },
    "devDependencies": {
        "@types/node": "^22.10.0",
        "@types/vscode": "^1.85.0",
        "typescript": "^5.7.3"
    }
}