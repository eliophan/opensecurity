    },
    {
      "id": "c-weak-crypto",
      "title": "Weak Crypto",
      "severity": "medium",
      "owasp": "A02:2021 Cryptographic Failures",
      "kind": "direct",
      "calleePattern": ["*MD5*", "*SHA1*", "MD5", "SHA1"]
    },
    {
      "id": "c-hardcoded-secret",
      "title": "Hardcoded Secret",
      "severity": "medium",
      "owasp": "A02:2021 Cryptographic Failures",
      "kind": "secret",
      "literalPattern": "(api|secret|token|password|passwd|pwd|key)[^\\n\\r]{0,20}[\"'][A-Za-z0-9_\\-]{8,}[\"']"
    }
  ]
