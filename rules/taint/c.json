      "sources": [
        { "id": "getenv", "name": "getenv", "matcher": { "callee": ["getenv"] } },
        { "id": "scanf", "name": "scanf", "matcher": { "calleePattern": ["scanf", "fscanf", "sscanf"] } },
        { "id": "gets", "name": "gets", "matcher": { "callee": ["gets", "fgets"] } }
      ],
      "sinks": [
        { "id": "fopen", "name": "fopen", "matcher": { "callee": ["fopen", "open", "read"] } }
      ]
    },
