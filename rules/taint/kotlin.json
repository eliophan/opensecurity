{
  "language": "kotlin",
  "rules": [
    {
      "id": "kt-sqli",
      "title": "SQL Injection",
      "severity": "high",
      "owasp": "A03:2021 Injection",
      "kind": "taint",
      "sources": [
        { "id": "param", "name": "request.getParameter", "matcher": { "calleePattern": ["*.getParameter", "*.getHeader"] } }
      ],
      "sinks": [
        { "id": "jdbc", "name": "Statement.execute", "matcher": { "calleePattern": ["*.execute", "*.executeQuery", "*.executeUpdate"] } }
      ]
    },
    {
      "id": "kt-cmd",
      "title": "Command Injection",
      "severity": "high",
      "owasp": "A03:2021 Injection",
      "kind": "taint",
      "sources": [
        { "id": "param", "name": "request.getParameter", "matcher": { "calleePattern": ["*.getParameter", "*.getHeader"] } }
      ],
      "sinks": [
        { "id": "runtime", "name": "Runtime.exec", "matcher": { "calleePattern": ["Runtime.getRuntime.exec", "*.exec"] } }
      ]
    },
    {
      "id": "kt-path",
      "title": "Path Traversal",
      "severity": "high",
      "owasp": "A01:2021 Broken Access Control",
      "kind": "taint",
      "sources": [
        { "id": "param", "name": "request.getParameter", "matcher": { "calleePattern": ["*.getParameter", "*.getHeader"] } }
      ],
      "sinks": [
        { "id": "file", "name": "Files.readAllBytes", "matcher": { "calleePattern": ["Files.readAllBytes", "Files.readString", "FileInputStream"] } }
      ]
    },
    {
      "id": "kt-ssrf",
      "title": "Server-Side Request Forgery",
      "severity": "high",
      "owasp": "A10:2021 Server-Side Request Forgery",
      "kind": "taint",
      "sources": [
        { "id": "param", "name": "request.getParameter", "matcher": { "calleePattern": ["*.getParameter", "*.getHeader"] } }
      ],
      "sinks": [
        { "id": "url", "name": "URL.openConnection", "matcher": { "calleePattern": ["*.openConnection"] } }
      ]
    },
    {
      "id": "kt-deser",
      "title": "Unsafe Deserialization",
      "severity": "high",
      "owasp": "A08:2021 Software and Data Integrity Failures",
      "kind": "taint",
      "sources": [
        { "id": "param", "name": "request.getParameter", "matcher": { "calleePattern": ["*.getParameter", "*.getHeader"] } }
      ],
      "sinks": [
        { "id": "java-io", "name": "ObjectInputStream.readObject", "matcher": { "calleePattern": ["ObjectInputStream.readObject", "*.readObject"] } },
        { "id": "jackson", "name": "ObjectMapper.readValue", "matcher": { "calleePattern": ["ObjectMapper.readValue", "*.readValue"] } },
        { "id": "gson", "name": "Gson.fromJson", "matcher": { "calleePattern": ["Gson.fromJson", "*.fromJson"] } }
      ]
    },
    {
      "id": "kt-xss-template",
      "title": "Server Template XSS",
      "severity": "medium",
      "owasp": "A03:2021 Injection",
      "kind": "taint",
      "sources": [
        { "id": "param", "name": "request.getParameter", "matcher": { "calleePattern": ["*.getParameter", "*.getHeader"] } }
      ],
      "sinks": [
        { "id": "tmpl", "name": "render", "matcher": { "calleePattern": ["render", "*.render"] } }
      ]
    },
    {
      "id": "kt-weak-crypto",
      "title": "Weak Crypto",
      "severity": "medium",
      "owasp": "A02:2021 Cryptographic Failures",
      "kind": "direct",
      "calleePattern": ["*MD5*", "*SHA1*"]
    },
    {
      "id": "kt-hardcoded-secret",
      "title": "Hardcoded Secret",
      "severity": "medium",
      "owasp": "A02:2021 Cryptographic Failures",
      "kind": "secret",
      "literalPattern": "(api|secret|token|password|passwd|pwd|key)[^\\n\\r]{0,20}[\"'][A-Za-z0-9_\\-]{8,}[\"']"
    }
  ]
}
